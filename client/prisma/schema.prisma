generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Call {
  id         String   @id
  callerId   String
  accepterId String?
  roomId     String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model Channel {
  id                String              @id @db.Uuid
  name              String
  description       String?
  createdAt         DateTime            @default(now())
  serverId          String?             @db.Uuid
  Server            Server?             @relation(fields: [serverId], references: [id])
  ChannelMembership ChannelMembership[]
  Message           Message[]
}

model ChannelMembership {
  id        String    @id @db.Uuid
  channelId String    @db.Uuid
  userId    String    @db.Uuid
  joinedAt  DateTime? @default(now())
  Channel   Channel   @relation(fields: [channelId], references: [id])
  User      User      @relation(fields: [userId], references: [id])
}

model Friendship {
  senderId                         String   @db.Uuid
  receiverId                       String   @db.Uuid
  status                           String
  createdAt                        DateTime @default(now())
  User_Friendship_receiverIdToUser User     @relation("Friendship_receiverIdToUser", fields: [receiverId], references: [id])
  User_Friendship_senderIdToUser   User     @relation("Friendship_senderIdToUser", fields: [senderId], references: [id])

  @@id([senderId, receiverId])
}

model Message {
  id        String   @id @db.Uuid
  channelId String   @db.Uuid
  userId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  Channel   Channel  @relation(fields: [channelId], references: [id])
  User      User     @relation(fields: [userId], references: [id])
}

model Server {
  id               String             @id @db.Uuid
  createdAt        DateTime           @default(now())
  name             String             @default("-1")
  thumbnail        String?
  description      String?
  Channel          Channel[]
  ServerMembership ServerMembership[]
}

model ServerMembership {
  id        String   @id @db.Uuid
  createdAt DateTime @default(now())
  serverId  String?  @db.Uuid
  userId    String?  @db.Uuid
  Server    Server?  @relation(fields: [serverId], references: [id])
  User      User?    @relation(fields: [userId], references: [id])
}

model User {
  name                                   String
  email                                  String              @unique
  createdAt                              DateTime            @default(now())
  password                               String
  id                                     String              @id @db.Uuid
  ChannelMembership                      ChannelMembership[]
  Friendship_Friendship_receiverIdToUser Friendship[]        @relation("Friendship_receiverIdToUser")
  Friendship_Friendship_senderIdToUser   Friendship[]        @relation("Friendship_senderIdToUser")
  Message                                Message[]
  ServerMembership                       ServerMembership[]
}
