# Congruity Self-Hosted Configuration
# Copy this file to .env and fill in the values

############
# REQUIRED #
############

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-postgres-password

# Generate with: openssl rand -base64 32
# Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# Generate these using the Supabase JWT generator or similar tool
# See: https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

############
# OPTIONAL #
############

# External URLs
SITE_URL=http://localhost:5173
API_EXTERNAL_URL=http://localhost:8000

# Ports
POSTGRES_PORT=5432
API_PORT=8000
API_SSL_PORT=8443
SIGNALING_PORT=3001

# JWT
JWT_EXPIRY=3600

# Auth settings
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP (for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=

# Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-password

# Realtime
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# MinIO (self-hosted media storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=congruity-media
MINIO_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
